{
  "projectRoot": ".",
  "html": {
    "paths": [
      "index.html",
      "about.html",
      "gallery.html",
      "projects.html",
      "videos.html",
      "podcasts.html",
      "blog.html",
      "contact.html",
      "master/header.html"
    ]
  },
  "css": {
    "paths": [
      "assets/css/global.css",
      "assets/css/header.css",
      "assets/css/sound-engine.css",
      "master/css/master.css"
    ]
  },
  "js": {
    "paths": [
      "master/js/master.js",
      "assets/js/theme.js",
      "assets/js/sound-engine.js",
      "assets/js/home.js"
    ]
  },
  "rules": {
    "checkHeaderIcons": true,
    "checkShimmerConflicts": true,
    "checkDuplicateSelectors": true,
    "checkMissingIds": true,
    "checkScriptOrder": true
  },
  "report": {
    "path": "tools/mother/mother-report.md"
  }
}
