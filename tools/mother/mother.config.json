{
  "cssGlobs": [
    "assets/css/**/*.css"
  ],

  "htmlGlobs": [
    "*.html"
  ],

  "jsGlobs": [
    "assets/js/**/*.js"
  ],

  "overflowMaxVW": 100,
  "overflowMaxVH": 100,

  "zIndexWarnThreshold": 500,

  "mobileBreakpoint": 900,

  "heroSelectors": [
    ".hero-section",
    ".hero-flex",
    ".hero-crown",
    ".day-background",
    ".night-background",
    ".day-clouds",
    ".night-nebula",
    ".magic-particles",
    ".gallery-lane"
  ]
}
