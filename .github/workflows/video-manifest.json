name: Build Video Manifest

on:
  push:
    paths:
      - "assets/videos/**"
      - ".github/workflows/video-manifest.yml"
  workflow_dispatch:

jobs:
  build-manifest:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Generate video-manifest.json
        run: |
          cd assets/videos
          echo "{" > video-manifest.json
          echo '  "videos": [' >> video-manifest.json

          first=true
          for file in *.mp4 2>/dev/null; do
            base="${file%.*}"
            thumb="${base}.jpg"

            if [ "$first" = true ]; then
              echo "    {\"file\": \"${file}\", \"thumbnail\": \"${thumb}\", \"title\": \"${base}\", \"description\": \"\"}" >> video-manifest.json
              first=false
            else
              echo "    ,{\"file\": \"${file}\", \"thumbnail\": \"${thumb}\", \"title\": \"${base}\", \"description\": \"\"}" >> video-manifest.json
            fi
          done

          echo "  ]" >> video-manifest.json
          echo "}" >> video-manifest.json

      - name: Commit updated manifest
        run: |
          git config user.name "github-actions"
          git config user.email "github-actions@github.com"
          git add assets/videos/video-manifest.json
          git commit -m "Auto-update video manifest" || echo "No changes to commit"

      - name: Push changes
        uses: ad-m/github-push-action@v0.8.0
        with:
          github_token: ${{ secrets.GITHUB_TOKEN }}
